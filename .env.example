# Bowmenn API — environment variables
# Every value below has a working default for local development except where noted.
# Copy to .env (or export in your shell / set in your host's config) and override.

# ---- Database ----
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bowmenn
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# ---- Auth ----
# REQUIRED IN PRODUCTION. Base64-encoded, >= 256 bits.
# Generate one:  openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRATION=86400000

# ---- File storage ----
# Tip: instead of env vars you can create bowmenn-api/bowmenn-local.properties
# (gitignored, auto-loaded) with the Spring property names, e.g.:
#     storage.provider=imagekit
#     imagekit.url-endpoint=https://ik.imagekit.io/<your_id>
#     imagekit.public-key=public_...
#     imagekit.private-key=private_...

# "local"    -> writes to UPLOAD_DIR, served at /uploads/** (default; no credentials)
# "imagekit" -> uploads to ImageKit; requires the IMAGEKIT_* values below
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads

# Only needed when STORAGE_PROVIDER=imagekit
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_FOLDER=/bowmenn/pod

# ---- Server ----
PORT=8080
